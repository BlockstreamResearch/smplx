// Wrapper module required for proper test suite integration.
pub mod wrapper {
    use math::simple_op::hash as temp_hash;

    pub fn get_root(tx1: u32, tx2: u32) -> u32 {
        temp_hash(tx1, tx2)
    }

    pub fn hash(tx1: u32, tx2: u32) -> u32 {
        jet::and_32(tx1, tx2)
    }
}

pub use crate::wrapper::{get_root, hash};
